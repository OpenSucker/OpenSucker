# ============================================================
# OpenSucker backend — environment variables
# Copy to .env and fill in real values.  .env is gitignored.
# ============================================================

# ---- LLM provider (OpenAI-compatible) ----
# 例: SiliconFlow / openai-next / 自建网关
LLM_API_KEY=sk-your-key-here
LLM_API_BASE=https://api.openai-next.com
LLM_API_MODEL=gpt-4o

# ---- Server ----
PORT=7860

# ---- 范式开关 ----
# 0 = state machine (硬编码 if-else, 快)
# 1 = function calling (LLM 自主调工具, 灵活)
USE_FUNCTION_CALLING=1

# ---- 外部工具 (可选, 留空则降级) ----
# FACE_API_URL=http://your-face-api/analyze
# RECOMMEND_API_URL=
COMFYUI_URL=https://comfyui.geekpie.tech
# STYLIST_API_URL=http://your-host/stylist/steps

# ---- 本地模型 (可选) ----
# MODEL_PATH=/path/to/Qwen2.5-1.5B-Instruct
# LORA_PATH=/path/to/lora_adapters
