# ============================================================
# OpenSucker — repository-wide .gitignore
# ============================================================

# ---------- OS / Editor ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.swp
*.swo
*.sw?
*.suo
*.ntvs*
*.njsproj
*.sln

# ---------- Environment / Secrets ----------
.env
.env.*
!.env.example
*.pem
*.key

# ---------- Logs ----------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# Python / Backend (uv managed)
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
*.egg
MANIFEST

# Virtual environments (uv / venv / poetry / pipenv)
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# uv
# NOTE: uv.lock SHOULD be committed — do not ignore it.
# .uv-cache is only used when UV_CACHE_DIR points locally
.uv-cache/

# Test / coverage / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.cache
nosetests.xml

# Jupyter / IPython
.ipynb_checkpoints/
profile_default/
ipython_config.py

# ============================================================
# Node / Frontend (Vite + React)
# ============================================================
node_modules/
dist/
dist-ssr/
build/
.next/
out/
.vite/
*.local

# Package manager debug / cache
.npm/
.yarn/
.pnp.*
.pnpm-store/

# ============================================================
# Project-specific artifacts
# ============================================================
# SQLite databases generated at runtime
*.db
*.sqlite
*.sqlite3

# Backend runtime output
backend/uploads/
backend/temp_backtests/
backend/data/__pycache__/

# Frontend build output (also covered above, listed for clarity)
frontend/dist/
frontend/node_modules/

# Misc temp
tmp/
temp/
*.tmp
*.bak
